<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.example.abxoverflow.droppedapk.preference.MaterialSwitchPreference
        android:key="@string/pref_key_display_color_native_mode"
        android:title="@string/display_color_override_native"
        android:summary="@string/display_color_override_native_subtitle"
        app:iconSpaceReserved="false" />

    <com.example.abxoverflow.droppedapk.preference.MaterialSeekbarPreference
        android:key="@string/pref_key_display_color_saturation"
        android:title="@string/display_color_saturation"
        app:minValue="0"
        app:maxValue="3"
        app:defaultValue="1"
        app:showSeekBarValue="true"
        app:allowDividerAbove="false"
        app:updatesContinuously="true" />

    <com.example.abxoverflow.droppedapk.preference.DemoImagePreference />

</androidx.preference.PreferenceScreen>
